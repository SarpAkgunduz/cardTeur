{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cardteur",
  "compatibility_date": "2026-05-11",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "openteur/dist",
    "not_found_handling": "single-page-application"
  },
